# Keep the Docker build context minimal and platform-clean.
#
# CRITICAL: node_modules must be excluded. The host installs darwin binaries
# (esbuild/sharp etc.); the build stage runs its own `pnpm install` for linux.
# Letting host node_modules into the context would bloat it and risk shipping
# wrong-platform native binaries into the build.

# Dependencies — reinstalled inside the build stage
node_modules
**/node_modules

# Build outputs — regenerated by `pnpm run build`
dist
dev-dist
dist-ssr
*.tsbuildinfo

# Version control & CI
.git
.gitignore
.github

# Editor / OS / local tooling
.vscode
.idea
.DS_Store
*.local

# Claude / agent-team runtime (not part of the app)
.claude
orchestrator
specs
TWA.md
DEPLOY.md
README.md
*.md

# Docker / deploy artifacts (not needed to build the image)
Dockerfile
.dockerignore
docker-compose.yml
scripts/deploy.sh
scripts/vps-setup.sh

# Logs & misc
*.log
npm-debug.log*
pnpm-debug.log*
coverage
.cache
